<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/content_view_big"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:paddingHorizontal="@dimen/padding_horizontal"
    android:paddingVertical="@dimen/padding_micro"
    android:orientation="vertical">

    <!-- Metadata: app icon, app name, timestamp (pre-v31 only) -->
    <include
        android:id="@+id/metadata"
        layout="@layout/metadata" />

    <!-- Body: image on left, text groups on right -->
    <RelativeLayout
        android:id="@+id/vertical_img_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingEnd="@dimen/padding_horizontal">

        <!-- Left: Vertical/portrait product image -->
        <include
            android:id="@+id/big_media_configurable"
            layout="@layout/image_media_dynamic_linear"
            android:layout_width="120dp"
            android:layout_height="180dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true" />

        <!-- Top-right: title + message, anchored to top -->
        <LinearLayout
            android:id="@+id/vertical_img_top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/big_media_configurable"
            android:layout_alignParentTop="true"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Airy Blur Blush Drops..."
                android:textAppearance="@style/PushTitle" />

            <TextView
                android:id="@+id/msg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Shop @ Myntra"
                android:textAppearance="@style/PushMessageMultiLine" />

        </LinearLayout>

        <!-- Bottom-right: text1 + text2 + button.
             layout_alignBottom anchors to image bottom when image is loaded.
             When image is GONE, RelativeLayout ignores that rule and
             layout_below kicks in, making everything stack sequentially. -->
        <LinearLayout
            android:id="@+id/vertical_img_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/big_media_configurable"
            android:layout_below="@id/vertical_img_top"
            android:layout_alignBottom="@id/big_media_configurable"
            android:gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/vertical_img_text1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone"
                tools:text="New Launch from Molte..."
                android:textAppearance="@style/PushMessageMultiLine" />

            <TextView
                android:id="@+id/vertical_img_text2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone"
                tools:text="Style Parade"
                android:textAppearance="@style/PushMessageMultiLine" />

            <!-- CTA Button: FrameLayout with ImageView bg for gradient support -->
            <FrameLayout
                android:id="@+id/vertical_img_btn_frame"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:layout_gravity="start"
                android:background="@drawable/pt_vertical_img_btn_default_bg"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/vertical_img_btn_bg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:id="@+id/vertical_img_btn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/verticalImgBtnTextColor"
                    tools:text="SHOP" />
            </FrameLayout>

        </LinearLayout>

    </RelativeLayout>
</LinearLayout>