<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/content_view_small"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="4dp"
    android:paddingTop="@dimen/padding_micro"
    android:paddingBottom="@dimen/padding_micro">

    <!-- Left: Title + msg — fills all remaining space -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:orientation="vertical"
        android:layout_marginEnd="6dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Airy Blur Blush..."
            android:textAppearance="@style/PushTitle" />

        <TextView
            android:id="@+id/msg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="New Launch fro..."
            android:textAppearance="@style/PushMessage" />

    </LinearLayout>

    <!-- Middle: Small product image thumbnail -->
    <include
        android:id="@+id/big_media_configurable"
        layout="@layout/image_media_dynamic_linear"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="6dp" />

    <!-- Right: CTA button — hugs right edge -->
    <FrameLayout
        android:id="@+id/vertical_img_btn_frame"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="28dp"
        android:layout_marginEnd="6dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/vertical_img_btn_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/vertical_img_btn"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center"
            android:singleLine="true"
            android:ellipsize="end"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="SHOP" />
    </FrameLayout>

</LinearLayout>
